# Basic settings
DOMAIN=example.com
EMAIL=your_email@example.com

# Web server settings
HTTP_PORT=80
HTTPS_PORT=443

# Trojan settings
TROJAN_PASSWORD=your_secure_password
TROJAN_REMOTE_ADDR=nginx
TROJAN_REMOTE_PORT=80

# DNSPod API credentials
DP_Id=your_dnspod_id
DP_Key=your_dnspod_key

# ACME settings
ACME_SERVER=https://acme.litessl.com/acme/v2/directory
SPACESHIP_API_KEY=your_spaceship_api_key
SPACESHIP_API_SECRET=your_spaceship_api_secret

# Timezone
TZ=UTC 
